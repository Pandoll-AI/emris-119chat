# LLM provider selection
# Supported: gemini, z.ai, x.ai, lm-studio, chatgpt
LLM_PROVIDER=gemini

# Google Gemini API
# Gemini만 GEMINI_API_KEY, GEMINI_API_KEY_1..._10 랜덤 로테이션을 지원합니다.
GEMINI_API_KEY=your-gemini-api-key
# GEMINI_API_KEY_1=  # 추가 키 (rate limit 분산용, 최대 10개)
# GEMINI_API_KEY_2=
GEMINI_API_MODEL=gemini-2.5-flash-lite

# z.ai OpenAI-compatible Chat Completions
# LLM_PROVIDER=z.ai
# ZAI_API_KEY=your-zai-api-key
# ZAI_API_MODEL=glm-5.1
# ZAI_API_BASE_URL=https://api.z.ai/api/paas/v4

# x.ai OpenAI-compatible Chat Completions
# LLM_PROVIDER=x.ai
# XAI_API_KEY=your-xai-api-key
# XAI_API_MODEL=grok-4
# XAI_API_BASE_URL=https://api.x.ai/v1

# OpenAI / ChatGPT Chat Completions
# LLM_PROVIDER=chatgpt
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_API_MODEL=gpt-4.1-mini
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# LM Studio local OpenAI-compatible server
# LLM_PROVIDER=lm-studio
# LMSTUDIO_API_MODEL=loaded-model-name
# LMSTUDIO_API_BASE_URL=http://127.0.0.1:1234/v1

# Optional global overrides
# LLM_API_MODEL=provider-model-name
# LLM_TIMEOUT_MS=30000
# LLM_TEMPERATURE=0.2

# LLM proxy logs
# Local default log file: .run/llm-proxy.jsonl
# Local default payload logging: on. Vercel default payload logging: off.
# LLM_LOG_FILE=.run/llm-proxy.jsonl
# LLM_LOG_PAYLOADS=1

# EMRIS 프록시 인증 토큰
EMRIS_API_KEY=your-emris-api-key
