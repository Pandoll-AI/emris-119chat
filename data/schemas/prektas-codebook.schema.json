{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emris.local/schemas/prektas-codebook.schema.json",
  "title": "Pre-KTAS Codebook",
  "description": "Canonical 5-character Pre-KTAS code catalog generated from the official Pre-KTAS_codebook.csv. Code layout: [group][level2][level3][level4 (2 chars)]. group 'C'=adult, 'D'=pediatric. Every entry is fully labeled — Pre-KTAS has no reserved/unlabeled codes of its own.",
  "type": "object",
  "required": ["version", "source", "stats", "entries"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "source": {
      "type": "object",
      "required": ["file", "sha256", "extracted_at"],
      "additionalProperties": false,
      "properties": {
        "file": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "extracted_at": { "type": "string", "format": "date-time" }
      }
    },
    "stats": {
      "type": "object",
      "required": ["total", "by_group", "level2_category_count"],
      "additionalProperties": false,
      "properties": {
        "total": { "type": "integer", "minimum": 1 },
        "by_group": {
          "type": "object",
          "required": ["adult", "pediatric"],
          "additionalProperties": false,
          "properties": {
            "adult": { "type": "integer", "minimum": 0 },
            "pediatric": { "type": "integer", "minimum": 0 }
          }
        },
        "level2_category_count": { "type": "integer", "minimum": 1 }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "required": ["code", "group", "grade", "level2", "level3", "level4"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "pattern": "^[CD][A-Z]{4}$" },
        "group": { "enum": ["adult", "pediatric"] },
        "grade": { "type": "integer", "minimum": 1, "maximum": 5 },
        "level2": { "$ref": "#/$defs/leafSingle" },
        "level3": { "$ref": "#/$defs/leafSingle" },
        "level4": { "$ref": "#/$defs/leafDouble" }
      }
    },
    "leafSingle": {
      "type": "object",
      "required": ["code", "name"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z]$" },
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "leafDouble": {
      "type": "object",
      "required": ["code", "name"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z]{2}$" },
        "name": { "type": "string", "minLength": 1 }
      }
    }
  }
}
